.page {
  min-height: 100vh;
  background: #FAFAF8;
  position: relative;
}

/* Navigation bar */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #FAFAF8;
  z-index: 100;
}

.nav-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 40rpx;
  height: 88rpx;
}

.nav-left {
  display: flex;
  align-items: baseline;
}

.brand-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-right: 16rpx;
}

.nav-date {
  font-size: 26rpx;
  color: #B5B5B5;
}

.search-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
}

.search-btn:active {
  background: #F0EFED;
}

.search-btn text {
  font-size: 36rpx;
}

/* Scroll area */
.scroll-area {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
}

.section-gap {
  height: 16rpx;
}

/* Events section */
.events-section {
  padding: 20rpx 40rpx 0;
}

.events-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  margin-top: 20rpx;
}

.events-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.legend {
  display: flex;
  align-items: center;
}

.legend-item {
  display: flex;
  align-items: center;
  margin-left: 16rpx;
}

.legend-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 6rpx;
}

.dot-school { background: #4A90D9; }
.dot-training { background: #5BB784; }
.dot-medical { background: #E8856C; }
.dot-family { background: #E8B44C; }

.legend-item text {
  font-size: 22rpx;
  color: #B5B5B5;
}

/* Date groups */
.date-group {
  margin-bottom: 24rpx;
}

.date-label-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.date-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.relative-badge {
  background: #1A1A1A;
  border-radius: 10rpx;
  padding: 2rpx 16rpx;
  margin-left: 12rpx;
}

.relative-badge text {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 600;
}

/* Empty state */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #8C8C8C;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #B5B5B5;
  text-align: center;
}

/* FAB */
.fab {
  position: fixed;
  right: 48rpx;
  bottom: 168rpx;
  width: 112rpx;
  height: 112rpx;
  background: #1A1A1A;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.2);
  z-index: 50;
}

.fab:active {
  transform: scale(0.95);
}

.fab-icon {
  font-size: 44rpx;
}
