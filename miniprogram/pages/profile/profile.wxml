<view class="page">
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content" style="height: {{menuBtnHeight}}px; margin-top: {{menuBtnMarginTop}}px;">
      <text class="page-title">我的</text>
    </view>
  </view>

  <scroll-view scroll-y class="scroll-area" style="top: {{navHeight}}px;">
    <!-- Stats card -->
    <view class="stats-card">
      <view class="stat-item">
        <text class="stat-num">{{stats.total}}</text>
        <text class="stat-label">全部事项</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">{{stats.pending}}</text>
        <text class="stat-label">待完成</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">{{stats.completed}}</text>
        <text class="stat-label">已完成</text>
      </view>
    </view>

    <!-- Notes -->
    <view class="notes-header">
      <text class="notes-title">便签</text>
      <view class="notes-count-tag" wx:if="{{noteCount > 0}}">
        <text>{{noteCount}}条</text>
      </view>
    </view>

    <view class="notes-list">
      <view
        class="note-swipe-container"
        wx:for="{{notes}}"
        wx:key="id"
      >
        <view class="note-swipe-actions">
          <view class="note-action-complete" catchtap="completeNote" data-id="{{item.id}}" wx:if="{{!item.completed}}">完成</view>
          <view class="note-action-delete" catchtap="deleteNote" data-id="{{item.id}}">删除</view>
        </view>

        <view
          class="note-card {{item.completed ? 'note-done' : ''}}"
          style="transform: translateX({{item.swipeX}}rpx);"
          bindtouchstart="onNoteTouchStart"
          bindtouchmove="onNoteTouchMove"
          bindtouchend="onNoteTouchEnd"
          data-idx="{{index}}"
        >
          <view class="note-bar"></view>
          <view class="note-body">
            <text class="note-content">{{item.content}}</text>
            <text class="note-time">{{item.timeAgo}}</text>
          </view>
        </view>
      </view>

      <!-- Empty state -->
      <view class="notes-empty" wx:if="{{notes.length === 0}}">
        <text class="notes-empty-text">随手记点事，别忘了就好</text>
      </view>
    </view>

    <!-- Collapsible settings -->
    <view class="collapse-header" bindtap="toggleSettings">
      <text class="collapse-title">设置与关于</text>
      <text class="collapse-arrow">{{settingsOpen ? '∨' : '﹥'}}</text>
    </view>

    <view wx:if="{{settingsOpen}}">
      <view class="settings-card">
        <view class="setting-row" bindtap="changeCity">
          <text class="setting-label">默认城市</text>
          <view class="setting-value">
            <text>{{city}}</text>
            <text class="arrow">→</text>
          </view>
        </view>
        <view class="setting-divider"></view>
        <view class="setting-row" bindtap="clearCompleted">
          <text class="setting-label">清除已完成事项</text>
          <view class="setting-value">
            <text class="arrow">→</text>
          </view>
        </view>
        <view class="setting-divider"></view>
        <view class="setting-row danger" bindtap="clearAll">
          <text class="setting-label">清除全部数据</text>
          <view class="setting-value">
            <text class="arrow">→</text>
          </view>
        </view>
        <view class="setting-divider"></view>
        <view class="setting-row">
          <text class="setting-label">版本</text>
          <view class="setting-value">
            <text class="version-text">1.1.0</text>
          </view>
        </view>
      </view>
    </view>

    <view style="height: 200rpx;"></view>
  </scroll-view>

  <!-- FAB -->
  <view class="fab" bindtap="showNoteModal">
    <text class="fab-icon">+</text>
  </view>

  <!-- Note input modal -->
  <view class="modal-mask" wx:if="{{noteModalVisible}}" bindtap="hideNoteModal">
    <view class="modal-panel" catchtap="">
      <view class="modal-title">添加便签</view>
      <textarea
        class="note-textarea"
        placeholder="随手记点事..."
        placeholder-style="color:#B5B5B5;font-size:28rpx;"
        value="{{noteInput}}"
        bindinput="onNoteInput"
        focus="{{noteModalVisible}}"
        cursor-spacing="120"
        auto-height
        maxlength="-1"
      />
      <view class="note-submit-btn {{noteInput ? 'btn-active' : ''}}" bindtap="submitNote">
        <text>保存</text>
      </view>
    </view>
  </view>
</view>
