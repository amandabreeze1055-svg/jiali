.page {
  min-height: 100vh;
  background: #FAFAF8;
}

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #FAFAF8;
  z-index: 100;
}

.nav-content {
  display: flex;
  align-items: center;
  padding: 0 40rpx;
}

.page-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.scroll-area {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
}

/* Stats card */
.stats-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  border: 1rpx solid #F0EFED;
  margin: 24rpx 40rpx 0;
  padding: 32rpx;
  display: flex;
  align-items: center;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #1A1A1A;
  line-height: 1.2;
}

.stat-label {
  font-size: 24rpx;
  color: #B5B5B5;
  margin-top: 4rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #F0EFED;
}

/* Section title */
.section-title {
  padding: 32rpx 40rpx 12rpx;
}

.section-title text {
  font-size: 28rpx;
  font-weight: 600;
  color: #8C8C8C;
}

/* Settings card */
.settings-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  border: 1rpx solid #F0EFED;
  margin: 0 40rpx;
}

.setting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
}

.setting-row:active {
  background: #FAFAF8;
}

.setting-label {
  font-size: 30rpx;
  color: #1A1A1A;
}

.setting-value {
  display: flex;
  align-items: center;
}

.setting-value text {
  font-size: 28rpx;
  color: #8C8C8C;
}

.arrow {
  margin-left: 8rpx;
  color: #B5B5B5;
}

.version-text {
  font-size: 26rpx;
  color: #B5B5B5;
}

.setting-divider {
  height: 1rpx;
  background: #F0EFED;
  margin: 0 32rpx;
}

.danger .setting-label {
  color: #E8856C;
}

/* Notes */
.notes-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 32rpx 40rpx 16rpx;
}

.notes-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.notes-count {
  font-size: 24rpx;
  color: #B5B5B5;
}

.notes-list {
  padding: 0 40rpx;
}

/* Note swipe */
.note-swipe-container {
  position: relative;
  overflow: hidden;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.note-swipe-actions {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
}

.note-action-complete {
  width: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #5BB784;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 600;
}

.note-action-delete {
  width: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #E8856C;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 600;
}

/* Note card */
.note-card {
  position: relative;
  z-index: 1;
  background: #FFFFFF;
  border-radius: 12rpx;
  border: 1rpx solid #F0EFED;
  display: flex;
  overflow: hidden;
  transition: transform 0.2s ease;
}

.note-card.note-done {
  opacity: 0.5;
}

.note-bar {
  width: 8rpx;
  background: #E8B44C;
  flex-shrink: 0;
}

.note-body {
  flex: 1;
  padding: 24rpx 28rpx;
  min-width: 0;
}

.note-content {
  font-size: 28rpx;
  color: #1A1A1A;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.5;
}

.note-done .note-content {
  text-decoration: line-through;
  color: #B5B5B5;
}

.note-time {
  font-size: 22rpx;
  color: #B5B5B5;
  display: block;
  text-align: right;
  margin-top: 8rpx;
}

/* Collapse header */
.collapse-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 40rpx;
  margin-top: 16rpx;
}

.collapse-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #8C8C8C;
}

.collapse-arrow {
  font-size: 26rpx;
  color: #B5B5B5;
}

/* Notes count tag */
.notes-count-tag {
  background: #F0EFED;
  border-radius: 20rpx;
  padding: 4rpx 16rpx;
}

.notes-count-tag text {
  font-size: 22rpx;
  color: #8C8C8C;
}

/* Notes empty state */
.notes-empty {
  padding: 60rpx 0;
  text-align: center;
}

.notes-empty-text {
  font-size: 26rpx;
  color: #B5B5B5;
}

/* FAB */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 80rpx;
  width: 96rpx;
  height: 96rpx;
  background: #1A1A1A;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
  z-index: 200;
}

.fab:active {
  opacity: 0.85;
}

.fab-icon {
  font-size: 48rpx;
  color: #FFFFFF;
  line-height: 1;
}

/* Modal */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 300;
  display: flex;
  align-items: flex-end;
}

.modal-panel {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 40rpx calc(40rpx + env(safe-area-inset-bottom));
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 24rpx;
}

.note-textarea {
  width: 100%;
  min-height: 160rpx;
  font-size: 28rpx;
  color: #1A1A1A;
  line-height: 1.6;
  padding: 20rpx 0;
  box-sizing: border-box;
}

.note-submit-btn {
  margin-top: 24rpx;
  padding: 20rpx 0;
  text-align: center;
  background: #E0E0E0;
  border-radius: 16rpx;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  transition: background 0.2s;
}

.note-submit-btn.btn-active {
  background: #1A1A1A;
}
