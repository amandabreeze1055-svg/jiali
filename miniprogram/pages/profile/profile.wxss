.page {
  min-height: 100vh;
  background: #FAFAF8;
}

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #FAFAF8;
  z-index: 100;
}

.nav-content {
  display: flex;
  align-items: center;
  padding: 0 40rpx;
}

.page-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.scroll-area {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
}

/* Stats card */
.stats-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  border: 1rpx solid #F0EFED;
  margin: 24rpx 40rpx 0;
  padding: 32rpx;
  display: flex;
  align-items: center;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #1A1A1A;
  line-height: 1.2;
}

.stat-label {
  font-size: 24rpx;
  color: #B5B5B5;
  margin-top: 4rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #F0EFED;
}

/* Section title */
.section-title {
  padding: 32rpx 40rpx 12rpx;
}

.section-title text {
  font-size: 28rpx;
  font-weight: 600;
  color: #8C8C8C;
}

/* Settings card */
.settings-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  border: 1rpx solid #F0EFED;
  margin: 0 40rpx;
}

.setting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
}

.setting-row:active {
  background: #FAFAF8;
}

.setting-label {
  font-size: 30rpx;
  color: #1A1A1A;
}

.setting-value {
  display: flex;
  align-items: center;
}

.setting-value text {
  font-size: 28rpx;
  color: #8C8C8C;
}

.arrow {
  margin-left: 8rpx;
  color: #B5B5B5;
}

.version-text {
  font-size: 26rpx;
  color: #B5B5B5;
}

.setting-divider {
  height: 1rpx;
  background: #F0EFED;
  margin: 0 32rpx;
}

.danger .setting-label {
  color: #E8856C;
}
