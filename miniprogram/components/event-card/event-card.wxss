/* Swipe container */
.swipe-container {
  position: relative;
  overflow: hidden;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
}

.swipe-content {
  position: relative;
  z-index: 1;
  transition: transform 0.2s ease;
}

.swipe-action {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #E8856C;
  border-radius: 0 24rpx 24rpx 0;
}

.swipe-action-text {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
}

.event-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  border: 1rpx solid #F0EFED;
  display: flex;
  overflow: hidden;
  transition: all 0.2s;
}

.event-card.editing {
  border-color: #4A90D9;
  box-shadow: 0 0 0 4rpx rgba(74, 144, 217, 0.1);
}

.event-card.uncertain {
  border-color: #F0DDB8;
}

/* Left color bar */
.color-bar {
  width: 8rpx;
  border-radius: 8rpx 0 0 8rpx;
  flex-shrink: 0;
}

.bar-school { background: #4A90D9; }
.bar-training { background: #5BB784; }
.bar-medical { background: #E8856C; }
.bar-family { background: #E8B44C; }

/* Card body */
.card-body {
  flex: 1;
  padding: 28rpx 32rpx;
  min-width: 0;
}

/* Row 1: Title + Time */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 8rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
  flex: 1;
  margin-right: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.time-badge {
  background: #F5F5F3;
  border-radius: 12rpx;
  padding: 4rpx 16rpx;
  flex-shrink: 0;
  font-size: 24rpx;
  color: #8C8C8C;
  font-weight: 500;
  white-space: nowrap;
}

/* Row 2: Date */
.card-date {
  font-size: 26rpx;
  color: #8C8C8C;
  display: block;
  margin-bottom: 8rpx;
}

/* Row 3: Location */
.card-location {
  font-size: 26rpx;
  color: #8C8C8C;
  display: block;
  margin-bottom: 16rpx;
}

/* Row 4: Notes section */
.notes-section {
  margin-bottom: 16rpx;
  padding-top: 8rpx;
  border-top: 1rpx solid #F5F5F3;
}

.notes-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #1A1A1A;
  display: block;
  margin-bottom: 8rpx;
  margin-top: 8rpx;
}

.notes-list {
  display: flex;
  flex-direction: column;
}

.note-line {
  font-size: 26rpx;
  color: #1A1A1A;
  line-height: 1.6;
  display: block;
}

/* Row 5: Prep items */
.prep-list {
  background: #F5F5F3;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 12rpx;
}

.prep-item {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.prep-item:last-child {
  margin-bottom: 0;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border-radius: 8rpx;
  border: 2rpx solid #E0E0E0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.checkbox.checked {
  background: #5BB784;
  border-color: #5BB784;
}

.checkbox-icon {
  font-size: 22rpx;
  color: #FFFFFF;
}

.prep-text {
  font-size: 26rpx;
  color: #1A1A1A;
}

.prep-done {
  text-decoration: line-through;
  color: #B5B5B5;
}

/* Row 6: Warning */
.uncertain-warn {
  background: #FFF8EC;
  border: 1rpx solid #F0DDB8;
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: #A07830;
}

/* Row 7: Category tags */
.tag-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
}

.copy-btn {
  font-size: 22rpx;
  color: #8C8C8C;
  margin-left: auto;
  padding: 4rpx 16rpx;
  border: 1rpx solid #E0E0E0;
  border-radius: 12rpx;
  background: #FAFAF8;
}

.copy-btn:active {
  background: #F0EFED;
}

.category-tag {
  border-radius: 12rpx;
  padding: 4rpx 16rpx;
  font-size: 22rpx;
  font-weight: 600;
  margin-right: 8rpx;
}

.tag-school {
  background: rgba(74, 144, 217, 0.1);
  color: #4A90D9;
}

.tag-training {
  background: rgba(91, 183, 132, 0.1);
  color: #5BB784;
}

.tag-medical {
  background: rgba(232, 133, 108, 0.1);
  color: #E8856C;
}

.tag-family {
  background: rgba(232, 180, 76, 0.1);
  color: #E8B44C;
}

/* Edit Mode */
.edit-mode {
  padding-top: 8rpx;
}

.edit-field {
  margin-bottom: 20rpx;
}

.edit-label {
  font-size: 24rpx;
  color: #8C8C8C;
  margin-bottom: 8rpx;
  display: block;
}

.edit-input {
  border: 1rpx solid #F0EFED;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #1A1A1A;
}

.edit-textarea {
  border: 1rpx solid #F0EFED;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #1A1A1A;
  width: 100%;
  box-sizing: border-box;
  min-height: 80rpx;
}

.edit-picker {
  border: 1rpx solid #F0EFED;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #1A1A1A;
}

.edit-row {
  display: flex;
}

.edit-field.half {
  flex: 1;
  margin-right: 16rpx;
}

.edit-field.half:last-child {
  margin-right: 0;
}

/* Category picker */
.category-picker {
  display: flex;
  flex-wrap: wrap;
}

.cat-option {
  border-radius: 12rpx;
  padding: 8rpx 24rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
  opacity: 0.5;
}

.cat-option.cat-active {
  opacity: 1;
  box-shadow: 0 0 0 2rpx currentColor;
}

/* Edit actions */
.edit-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0EFED;
}

.btn-cancel, .btn-delete, .btn-save {
  border-radius: 16rpx;
  padding: 12rpx 32rpx;
  margin-left: 16rpx;
}

.btn-cancel {
  background: #F5F5F3;
  color: #8C8C8C;
  font-size: 26rpx;
}

.btn-delete {
  background: rgba(232, 133, 108, 0.1);
  color: #E8856C;
  font-size: 26rpx;
}

.btn-save {
  background: #1A1A1A;
  color: #FFFFFF;
  font-size: 26rpx;
}
