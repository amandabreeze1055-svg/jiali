<view class="weekly-prep-container" wx:if="{{hasData}}">
  <!-- Section title -->
  <view class="section-header">
    <text class="section-title">本周准备</text>
    <view class="add-child-btn" bindtap="addChild">
      <text>+ 添加</text>
    </view>
  </view>

  <!-- Child cards -->
  <view
    class="prep-card"
    wx:for="{{children}}"
    wx:key="_id"
    wx:for-index="childIdx"
    wx:for-item="child"
  >
    <!-- Card header -->
    <view class="prep-card-head">
      <view>
        <view class="prep-title">
          <text>{{child.childName}}</text>
          <text class="prep-class" wx:if="{{child.className}}"> · {{child.className}}</text>
        </view>
        <view class="prep-subtitle">{{child.dateRange}}</view>
      </view>
      <view class="head-actions">
        <view class="prep-edit-btn" wx:if="{{!child.editingThis}}" bindtap="startEdit" data-child-idx="{{childIdx}}">编辑</view>
        <view class="prep-delete-btn" wx:if="{{!child.editingThis}}" bindtap="deleteChild" data-child-idx="{{childIdx}}">删除</view>
      </view>
    </view>

    <!-- View mode: 7-day grid -->
    <view class="prep-days" wx:if="{{!child.editingThis}}">
      <view
        class="prep-day {{day.isToday ? 'is-today' : ''}} {{day.hasPrep && !day.isToday ? 'has-content' : ''}} {{!day.hasPrep && !day.isToday ? 'empty' : ''}}"
        wx:for="{{child.days}}"
        wx:for-item="day"
        wx:key="weekday"
      >
        <view class="prep-day-header">
          <text class="prep-day-label">{{day.label}}</text>
          <text class="prep-day-date">{{day.dateNum}}</text>
        </view>
        <!-- Outfit layer -->
        <view class="prep-uniform" wx:if="{{day.outfit}}">
          <text class="prep-uniform-emoji">{{day.outfitEmoji}}</text>
          <text class="prep-uniform-text">{{day.outfit}}</text>
        </view>
        <!-- Items layer -->
        <view class="prep-items" wx:if="{{day.items.length > 0}}">
          <text class="prep-items-text" wx:for="{{day.items}}" wx:for-item="itm" wx:key="*this">{{itm}}</text>
        </view>
      </view>
    </view>

    <!-- Legend -->
    <view class="prep-legend" wx:if="{{!child.editingThis}}">
      <view class="prep-legend-item">
        <view class="prep-legend-dot dot-uniform"></view>
        <text class="prep-legend-text">着装</text>
      </view>
      <view class="prep-legend-item">
        <view class="prep-legend-dot dot-items"></view>
        <text class="prep-legend-text">携带物品</text>
      </view>
    </view>

    <!-- Edit mode -->
    <view class="prep-days" wx:if="{{child.editingThis}}">
      <view
        class="prep-day {{child.days[dayIdx].isToday ? 'is-today' : ''}}"
        wx:for="{{child.editDays}}"
        wx:for-item="ed"
        wx:for-index="dayIdx"
        wx:key="dayIdx"
      >
        <view class="prep-day-header">
          <text class="prep-day-label">{{child.days[dayIdx].label}}</text>
          <text class="prep-day-date">{{child.days[dayIdx].dateNum}}</text>
        </view>
        <input
          class="edit-input"
          value="{{ed.outfit}}"
          placeholder="穿搭"
          placeholder-style="color:#CCC;font-size:20rpx;"
          bindinput="onOutfitInput"
          data-child-idx="{{childIdx}}"
          data-day-idx="{{dayIdx}}"
        />
        <input
          class="edit-input"
          value="{{ed.itemsText}}"
          placeholder="物品"
          placeholder-style="color:#CCC;font-size:20rpx;"
          bindinput="onItemsInput"
          data-child-idx="{{childIdx}}"
          data-day-idx="{{dayIdx}}"
        />
      </view>
    </view>

    <!-- Edit actions -->
    <view class="edit-actions" wx:if="{{child.editingThis}}">
      <view class="btn-cancel" bindtap="cancelEdit" data-child-idx="{{childIdx}}">
        <text>取消</text>
      </view>
      <view class="btn-save" bindtap="saveEdit" data-child-idx="{{childIdx}}">
        <text>保存</text>
      </view>
    </view>
  </view>
</view>
