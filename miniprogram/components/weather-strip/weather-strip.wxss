.weather-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  border: 1rpx solid #F0EFED;
  padding: 20rpx 20rpx 20rpx 28rpx;
  margin: 0 32rpx 16rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.weather-today {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.weather-icon-lg {
  font-size: 36rpx;
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  margin-right: 8rpx;
  flex-shrink: 0;
  overflow: hidden;
}

.weather-today-info {
  display: flex;
  flex-direction: column;
  white-space: nowrap;
}

.weather-temp {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
  line-height: 1.1;
}

.weather-range {
  font-size: 18rpx;
  color: #B5B5B5;
  line-height: 1.3;
}

.weather-city {
  font-size: 18rpx;
  color: #8C8C8C;
  line-height: 1.3;
}

.weather-divider {
  width: 1rpx;
  height: 56rpx;
  background: #F0EFED;
  flex-shrink: 0;
}

.weather-forecast {
  display: flex;
  flex: 1;
  justify-content: space-around;
  min-width: 0;
}

.forecast-day {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 0;
}

.forecast-weekday {
  font-size: 18rpx;
  color: #B5B5B5;
  line-height: 1.4;
}

.forecast-icon {
  font-size: 24rpx;
  line-height: 1.4;
}

.forecast-temp {
  font-size: 18rpx;
  color: #8C8C8C;
  line-height: 1.4;
  white-space: nowrap;
}
