.preview-container {
  padding-top: 8rpx;
}

.preview-summary {
  background: #F5F5F3;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 24rpx;
}

.summary-text {
  font-size: 26rpx;
  color: #8C8C8C;
  font-weight: 500;
}

/* Schedule card */
.schedule-card {
  background: #FFFFFF;
  border: 1rpx solid #F0EFED;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.schedule-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
  display: block;
  margin-bottom: 4rpx;
}

.schedule-range {
  font-size: 24rpx;
  color: #8C8C8C;
  display: block;
  margin-bottom: 16rpx;
}

.schedule-grid {
  display: flex;
  overflow-x: auto;
}

.schedule-day {
  min-width: 120rpx;
  flex-shrink: 0;
  margin-right: 12rpx;
  background: #FAFAF8;
  border-radius: 12rpx;
  padding: 12rpx;
}

.sday-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #1A1A1A;
  display: block;
  margin-bottom: 8rpx;
}

.sday-uniform {
  font-size: 22rpx;
  color: #8C8C8C;
  display: block;
  margin-bottom: 4rpx;
}

.sday-items {
  margin-bottom: 4rpx;
}

.sday-item {
  font-size: 20rpx;
  color: #8C8C8C;
  display: block;
}

.sday-highlights {
  display: flex;
  flex-wrap: wrap;
}

.sday-hl {
  font-size: 20rpx;
  color: #4A90D9;
  background: rgba(74, 144, 217, 0.1);
  border-radius: 6rpx;
  padding: 2rpx 8rpx;
  margin-right: 4rpx;
  margin-top: 4rpx;
}

/* Section */
.preview-section {
  margin-bottom: 20rpx;
}

.section-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #8C8C8C;
  display: block;
  margin-bottom: 12rpx;
}

/* Preview event */
.preview-event {
  background: #FFFFFF;
  border: 1rpx solid #F0EFED;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
}

.event-uncertain {
  border-color: #F0DDB8;
}

.event-info-only {
  opacity: 0.6;
}

.pe-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.pe-bar {
  width: 6rpx;
  height: 32rpx;
  border-radius: 3rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.bar-school { background: #4A90D9; }
.bar-training { background: #5BB784; }
.bar-medical { background: #E8856C; }
.bar-family { background: #E8B44C; }

.pe-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
  flex: 1;
}

.pe-time {
  background: #F5F5F3;
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
  font-size: 22rpx;
  color: #8C8C8C;
}

.pe-date {
  font-size: 24rpx;
  color: #8C8C8C;
  display: block;
  margin-bottom: 8rpx;
}

.pe-notes {
  font-size: 26rpx;
  color: #8C8C8C;
  display: block;
  margin-bottom: 8rpx;
  line-height: 1.5;
}

.pe-prep {
  background: #FAFAF8;
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
  margin-bottom: 8rpx;
}

.pe-prep-item {
  font-size: 24rpx;
  color: #1A1A1A;
  display: block;
  line-height: 1.6;
}

.pe-info-badge {
  display: inline-block;
  background: #F5F5F3;
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
  font-size: 22rpx;
  color: #B5B5B5;
}

/* Info notes */
.info-note {
  background: #FAFAF8;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 8rpx;
  font-size: 26rpx;
  color: #8C8C8C;
}

/* Action buttons */
.preview-actions {
  display: flex;
  margin-top: 24rpx;
}

.btn-back {
  flex: 1;
  background: #F5F5F3;
  border-radius: 20rpx;
  padding: 24rpx;
  text-align: center;
  margin-right: 16rpx;
  font-size: 28rpx;
  color: #8C8C8C;
  font-weight: 500;
}

.btn-confirm {
  flex: 2;
  background: #1A1A1A;
  border-radius: 20rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 600;
}
