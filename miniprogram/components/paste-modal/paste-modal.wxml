<view class="modal-mask" wx:if="{{visible}}" bindtap="onClose">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-handle"></view>
    <text class="modal-title">添加日程</text>
    <text class="modal-subtitle">从聊天记录或照片中识别日程</text>

    <!-- Tab switcher -->
    <view class="tab-container">
      <view class="tab-item {{activeTab === 'paste' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="paste">
        <text>粘贴文字</text>
      </view>
      <view class="tab-item {{activeTab === 'photo' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="photo">
        <text>拍照识别</text>
      </view>
    </view>

    <!-- Paste panel -->
    <view class="panel" wx:if="{{activeTab === 'paste' && !showResult && !showActionConfirm}}">
      <view class="paste-area">
        <textarea
          class="paste-input"
          placeholder="{{pastePlaceholder}}"
          placeholder-style="color: #B5B5B5; font-size: 26rpx;"
          value="{{pasteText}}"
          bindinput="onPasteInput"
          cursor-spacing="120"
          show-confirm-bar="{{true}}"
          auto-height
          maxlength="-1"
        />
      </view>
      <view class="action-btn {{pasteText ? 'btn-active' : ''}}" bindtap="parseText">
        <text wx:if="{{!loading}}">识别日程</text>
        <text wx:if="{{loading}}">正在识别中...</text>
      </view>
    </view>

    <!-- Photo panel -->
    <view class="panel" wx:if="{{activeTab === 'photo' && !showResult && !showActionConfirm}}">
      <view class="photo-area" bindtap="choosePhoto">
        <view class="photo-placeholder" wx:if="{{photos.length === 0}}">
          <text class="photo-icon">📷</text>
          <text class="photo-hint">点击拍照或从相册选择</text>
        </view>
        <view class="photo-grid" wx:if="{{photos.length > 0}}">
          <image
            wx:for="{{photos}}"
            wx:key="*this"
            src="{{item}}"
            class="photo-thumb"
            mode="aspectFill"
          />
          <view class="photo-add" wx:if="{{photos.length < 4}}">
            <text>+</text>
          </view>
        </view>
      </view>
      <view class="action-btn {{photos.length > 0 ? 'btn-active' : ''}}" bindtap="parsePhoto">
        <text wx:if="{{!loading}}">识别日程</text>
        <text wx:if="{{loading}}">正在识别中...</text>
      </view>
    </view>

    <!-- Delete/Modify confirmation -->
    <view class="panel" wx:if="{{showActionConfirm}}">
      <view class="action-confirm">
        <!-- Header -->
        <view class="confirm-header">
          <text class="confirm-icon">{{actionType === 'delete' ? '🗑️' : '✏️'}}</text>
          <text class="confirm-title">{{actionType === 'delete' ? '确认删除' : '确认修改'}}</text>
        </view>
        <text class="confirm-desc">{{actionDescription}}</text>

        <!-- Matched events list -->
        <view class="confirm-list" wx:if="{{matchedEvents.length > 0}}">
          <text class="confirm-count">找到 {{matchedEvents.length}} 条相关事项：</text>
          <view class="confirm-event" wx:for="{{matchedEvents}}" wx:key="id">
            <view class="confirm-event-bar bar-{{item.category}}"></view>
            <view class="confirm-event-body">
              <text class="confirm-event-title">{{item.title}}</text>
              <text class="confirm-event-date">{{item.date}} {{item.time || ''}}</text>
            </view>
          </view>
        </view>

        <!-- No match -->
        <view class="confirm-empty" wx:if="{{matchedEvents.length === 0}}">
          <text class="confirm-empty-text">没有找到匹配的事项</text>
        </view>

        <!-- Modify changes preview -->
        <view class="confirm-changes" wx:if="{{actionType === 'modify' && matchedEvents.length > 0}}">
          <text class="confirm-changes-title">将修改为：</text>
          <view class="confirm-change-item" wx:for="{{changesList}}" wx:key="label">
            <text class="change-label">{{item.label}}</text>
            <text class="change-value">{{item.value}}</text>
          </view>
        </view>

        <!-- Action buttons -->
        <view class="confirm-actions">
          <view class="confirm-btn-cancel" bindtap="onBackToInput">
            <text>取消</text>
          </view>
          <view class="confirm-btn-ok {{matchedEvents.length === 0 ? '' : (actionType === 'delete' ? 'btn-danger' : 'btn-primary')}}" bindtap="executeAction" wx:if="{{matchedEvents.length > 0}}">
            <text>{{actionType === 'delete' ? '确认删除 (' + matchedEvents.length + ')' : '确认修改 (' + matchedEvents.length + ')'}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Parse result (add mode) -->
    <view class="panel" wx:if="{{showResult}}">
      <parsed-preview
        result="{{parseResult}}"
        bind:confirm="onConfirmAdd"
        bind:back="onBackToInput"
      />
    </view>
  </view>
</view>
