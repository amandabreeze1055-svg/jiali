.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  background: #FFFFFF;
  border-radius: 40rpx 40rpx 0 0;
  width: 100%;
  max-height: 85vh;
  padding: 20rpx 40rpx 60rpx;
  box-sizing: border-box;
  overflow-y: auto;
}

.modal-handle {
  width: 72rpx;
  height: 8rpx;
  background: #E0E0E0;
  border-radius: 4rpx;
  margin: 0 auto 24rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1A1A;
  display: block;
  margin-bottom: 8rpx;
}

.modal-subtitle {
  font-size: 26rpx;
  color: #8C8C8C;
  display: block;
  margin-bottom: 28rpx;
}

/* Tab switcher */
.tab-container {
  display: flex;
  background: #F5F5F3;
  border-radius: 20rpx;
  padding: 6rpx;
  margin-bottom: 28rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.tab-item text {
  font-size: 28rpx;
  font-weight: 500;
  color: #8C8C8C;
}

.tab-active {
  background: #FFFFFF;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.04);
}

.tab-active text {
  color: #1A1A1A;
}

/* Paste area */
.paste-area {
  border: 2rpx dashed #E0E0E0;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  min-height: 200rpx;
}

.paste-input {
  width: 100%;
  font-size: 28rpx;
  color: #1A1A1A;
  line-height: 1.6;
  min-height: 160rpx;
}

/* Photo area */
.photo-area {
  border: 2rpx dashed #E0E0E0;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  min-height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.photo-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.photo-icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.photo-hint {
  font-size: 26rpx;
  color: #B5B5B5;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  width: 100%;
}

.photo-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
}

.photo-add {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  border: 2rpx dashed #E0E0E0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.photo-add text {
  font-size: 48rpx;
  color: #B5B5B5;
}

/* Action button */
.action-btn {
  background: #E0E0E0;
  border-radius: 20rpx;
  padding: 24rpx;
  text-align: center;
}

.action-btn text {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.btn-active {
  background: #1A1A1A;
}
