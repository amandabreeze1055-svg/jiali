.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  background: #FFFFFF;
  border-radius: 40rpx 40rpx 0 0;
  width: 100%;
  max-height: 85vh;
  padding: 20rpx 40rpx 60rpx;
  box-sizing: border-box;
  overflow-y: auto;
}

.modal-handle {
  width: 72rpx;
  height: 8rpx;
  background: #E0E0E0;
  border-radius: 4rpx;
  margin: 0 auto 24rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1A1A;
  display: block;
  margin-bottom: 8rpx;
}

.modal-subtitle {
  font-size: 26rpx;
  color: #8C8C8C;
  display: block;
  margin-bottom: 28rpx;
}

/* Tab switcher */
.tab-container {
  display: flex;
  background: #F5F5F3;
  border-radius: 20rpx;
  padding: 6rpx;
  margin-bottom: 28rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 16rpx;
  transition: all 0.2s;
  font-size: 28rpx;
  font-weight: 500;
  color: #8C8C8C;
}

.tab-active {
  background: #FFFFFF;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.04);
  color: #1A1A1A;
}

/* Paste area */
.paste-area {
  border: 2rpx dashed #E0E0E0;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  min-height: 200rpx;
}

.paste-input {
  width: 100%;
  font-size: 28rpx;
  color: #1A1A1A;
  line-height: 1.6;
  min-height: 160rpx;
}

/* Photo area */
.photo-area {
  border: 2rpx dashed #E0E0E0;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  min-height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.photo-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.photo-icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.photo-hint {
  font-size: 26rpx;
  color: #B5B5B5;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  width: 100%;
}

.photo-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
}

.photo-add {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  border: 2rpx dashed #E0E0E0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #B5B5B5;
}

/* Action button */
.action-btn {
  background: #E0E0E0;
  border-radius: 20rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.btn-active {
  background: #1A1A1A;
}

/* Delete/Modify confirmation */
.action-confirm {
  padding-top: 8rpx;
}

.confirm-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.confirm-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.confirm-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.confirm-desc {
  font-size: 26rpx;
  color: #8C8C8C;
  display: block;
  margin-bottom: 24rpx;
}

.confirm-count {
  font-size: 24rpx;
  color: #8C8C8C;
  display: block;
  margin-bottom: 12rpx;
}

.confirm-list {
  margin-bottom: 24rpx;
}

.confirm-event {
  display: flex;
  align-items: center;
  background: #FAFAF8;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 8rpx;
}

.confirm-event-bar {
  width: 6rpx;
  height: 40rpx;
  border-radius: 3rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.confirm-event-body {
  flex: 1;
  min-width: 0;
}

.confirm-event-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1A1A1A;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.confirm-event-date {
  font-size: 22rpx;
  color: #8C8C8C;
  display: block;
}

.confirm-empty {
  background: #FAFAF8;
  border-radius: 16rpx;
  padding: 40rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.confirm-empty-text {
  font-size: 28rpx;
  color: #B5B5B5;
}

.confirm-changes {
  background: #F0F7FF;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}

.confirm-changes-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #4A90D9;
  display: block;
  margin-bottom: 8rpx;
}

.confirm-change-item {
  display: flex;
  align-items: center;
  margin-bottom: 4rpx;
}

.change-label {
  font-size: 26rpx;
  color: #8C8C8C;
  margin-right: 12rpx;
}

.change-value {
  font-size: 26rpx;
  color: #1A1A1A;
  font-weight: 500;
}

.confirm-actions {
  display: flex;
  gap: 16rpx;
}

.confirm-btn-cancel {
  flex: 1;
  background: #F5F5F3;
  border-radius: 20rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 28rpx;
  color: #8C8C8C;
  font-weight: 500;
}

.confirm-btn-ok {
  flex: 2;
  background: #E0E0E0;
  border-radius: 20rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.confirm-btn-ok.btn-danger {
  background: #E8856C;
}

.confirm-btn-ok.btn-primary {
  background: #1A1A1A;
}
